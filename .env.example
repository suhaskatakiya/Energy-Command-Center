# EnergyGuard AI Environment Variables Configuration

# Port settings (defaults to 8000 for backend)
PORT=8000
HOST=0.0.0.0

# SQLite connection URL (autocreated on launch)
DATABASE_URL=sqlite:///./energyguard.db

# Google Gemini API key for active news miners and RAG coordinators
# If left blank, the application will automatically fall back to rule-based parser mocks.
GEMINI_API_KEY=
